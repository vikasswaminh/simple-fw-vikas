FROM rust:1.83-bookworm
RUN apt-get update && apt-get install -y pkg-config libpcap-dev build-essential libssl-dev && rm -rf /var/lib/apt/lists/*
WORKDIR /build
COPY . .
RUN cargo build --release -p quickfw-api -p quickfw-cli -p quickfw-setup 2>&1
RUN cargo test --release -p quickfw-api 2>&1
RUN ls -lh target/release/quickfw-api target/release/quickfw target/release/quickfw-setup
